# Client build-time environment for production deployments.
#
# CRA (via craco) inlines any REACT_APP_* variable at build time — so you must
# set these BEFORE `bun run build`. Changing them after the fact requires a rebuild.
#
# Copy this file and replace the placeholder values with your actual server
# hostname + name before running `bun run build`.

# Full WebSocket URL of your game server. Use wss:// if the server sits behind
# a TLS-terminating reverse proxy (strongly recommended for public deployments
# so browsers on HTTPS pages can connect).
#
# Examples:
#   ws://game.example.com:43594        <- plain, public/LAN, no TLS
#   wss://game.example.com             <- behind Caddy on standard 443
#   wss://game.example.com:43594       <- behind Caddy on custom port
REACT_APP_WS_URL=wss://your-domain.example/ws

# Display name shown on the server-select button and in the server list.
REACT_APP_SERVER_NAME=My xRSPS Server
